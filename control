    <script>
        // Synchronize UI with Kernel on load
        window.onload = () => {
            const state = Kernel.state;
            document.getElementById('bright-slider').value = state.brightness;
            adjustBrightness(state.brightness);
            updateTileUI();
            refreshSource();
        };

        function adjustBrightness(val) {
            document.getElementById('bright-val').innerText = val + "%";
            Kernel.hardware.setBrightness(val);
        }

        function toggleHardware(key) {
            if (key === 'flashlight') {
                Kernel.hardware.toggleFlashlight();
            } else {
                Kernel.state[key] = !Kernel.state[key];
                Kernel.save();
            }
            updateTileUI();
            refreshSource();
        }

        function updateTileUI() {
            document.getElementById('tile-flash').classList.toggle('active', Kernel.state.flashlight);
            document.getElementById('tile-wifi').classList.toggle('active', Kernel.state.cellular);
        }

        function refreshSource() {
            // This displays the "Live Brain" in the dev panel
            const dump = document.getElementById('state-dump');
            dump.innerText = JSON.stringify(Kernel.state, null, 4);
        }
    </script>
