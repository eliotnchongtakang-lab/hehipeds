<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minetopia Apps</title>
    <script src="kernel.js"></script>
    <style>
        :root {
  d          --m-blue: #007aff;
            --m-glass: rgba(255, 255, 255, 0.05);
            --m-border: rgba(255, 255, 255, 0.1);
        }

        body {
            margin: 0; background: #000; color: #fff;
            font-family: 'Inter', sans-serif; height: 100vh;
            display: flex; flex-direction: column;
            overflow: hidden;
        }

        /* SEARCH & HEADER (Android 15 Style) */
        .header {
            padding: 50px 25px 20px;
            background: linear-gradient(to bottom, #000, transparent);
        }

        .search-bar {
            width: 100%; padding: 18px 25px; border-radius: 35px;
            background: #111; border: 1px solid var(--m-border);
            color: white; font-size: 16px; outline: none;
            box-shadow: 0 10px 40px rgba(0,0,0,0.8);
            box-sizing: border-box;
        }

        /* THE GRID AREA */
        .main-view {
            flex: 1; display: flex; overflow: hidden;
        }

        .app-grid {
            flex: 1; display: grid; 
            grid-template-columns: repeat(4, 1fr);
            grid-auto-rows: min-content; 
            gap: 30px; padding: 30px;
            overflow-y: auto;
        }

        /* ALPHABETIC SIDEBAR (iOS 26 Style) */
        .alpha-sidebar {
            width: 30px; display: flex; flex-direction: column;
            justify-content: space-between; padding: 40px 5px;
            font-size: 11px; font-weight: 900; color: var(--m-blue);
            background: rgba(0,0,0,0.3); text-align: center;
            opacity: 0.6;
        }

        /* APP ICON STYLING */
        .app-item {
            display: flex; flex-direction: column; align-items: center; 
            gap: 12px; text-decoration: none; color: white;
            transition: transform 0.2s;
        }
        .app-item:active { transform: scale(0.9); }

        .icon-box {
            width: 65px; height: 65px; border-radius: 20px;
            background: #fff; display: flex; align-items: center;
            justify-content: center; font-size: 35px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
        }

        .app-item span {
            font-size: 11px; font-weight: 600; letter-spacing: 0.5px;
            text-align: center; opacity: 0.9;
        }

        /* DOCK NAVIGATION */
        #dock {
            background: rgba(15, 15, 15, 0.9); backdrop-filter: blur(30px);
            padding: 15px 30px; border-radius: 40px; border: 1px solid var(--m-border);
            display: flex; gap: 30px; margin: 20px auto; width: fit-content;
            z-index: 100;
        }

        .dock-item {
            text-decoration: none; font-size: 24px; transition: 0.3s;
        }
    </style>
</head>
<body>

    <div class="header">
        <input type="text" class="search-bar" id="app-search" placeholder="Search Minetopia..." oninput="filterApps()">
    </div>

    <div class="main-view">
        <div class="app-grid" id="main-grid">
            </div>

        <div class="alpha-sidebar">
            <span>A</span><span>B</span><span>C</span><span>D</span><span>E</span><span>F</span><span>G</span><span>H</span><span>I</span><span>J</span><span>K</span><span>L</span><span>M</span><span>N</span><span>O</span><span>P</span><span>Q</span><span>R</span><span>S</span><span>T</span><span>U</span><span>V</span><span>W</span><span>X</span><span>Y</span><span>Z</span>
        </div>
    </div>

    <nav id="dock">
        <a href="foneai.html" class="dock-item">🧠</a>
        <a href="control.html" class="dock-item">⚙️</a>
        <a href="index.html" class="dock-item">🏠</a>
        <a href="apps.html" class="dock-item" style="color: var(--m-blue);">🔳</a>
    </nav>

    <script>
        // FUNCTION: RENDER FROM KERNEL BRAIN
        function renderApps() {
            const grid = document.getElementById('main-grid');
            
            // Getting apps currently stored in Kernel.state
            const apps = Kernel.state.installedApps;

            grid.innerHTML = apps.map(app => `
                <a href="${app.url}" class="app-item" data-name="${app.name.toLowerCase()}">
                    <div class="icon-box">${app.icon}</div>
                    <span>${app.name.toUpperCase()}</span>
                </a>
            `).join('');
        }

        // FUNCTION: SEARCH FILTER
        function filterApps() {
            const term = document.getElementById('app-search').value.toLowerCase();
            const items = document.querySelectorAll('.app-item');
            
            items.forEach(item => {
                const name = item.getAttribute('data-name');
                item.style.display = name.includes(term) ? 'flex' : 'none';
            });
        }

        // START
        window.onload = () => {
            renderApps();
        };
    </script>
</body>
</html>
