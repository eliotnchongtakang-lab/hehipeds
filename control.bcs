<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Minetopia Control BCS</title>
    <script src="kernel.js"></script>
    <style>
        :root { --m-blue: #007aff; --m-glass: rgba(255, 255, 255, 0.05); }
        body { 
            margin: 0; background: #000; color: #fff; font-family: 'Inter', sans-serif; 
            padding: 40px 20px; transition: 0.3s;
        }
        
        .control-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .pill-tile {
            background: #111; height: 70px; border-radius: 20px;
            display: flex; align-items: center; padding: 0 20px; gap: 15px;
            border: 1px solid rgba(255,255,255,0.1); cursor: pointer;
        }
        .pill-tile.active { background: var(--m-blue); border-color: transparent; }
        .pill-tile span { font-size: 12px; font-weight: 800; }

        .slider-box {
            background: var(--m-glass); padding: 25px; border-radius: 25px;
            margin: 30px 0; border: 1px solid rgba(255,255,255,0.1);
        }
        input[type=range] { width: 100%; accent-color: var(--m-blue); }

        /* DEVELOPER SOURCE PANEL */
        .dev-card {
            background: #0a0a0a; border-radius: 20px; padding: 20px;
            border: 1px solid #222; margin-bottom: 100px;
        }
        .code-block {
            background: #000; color: #0f0; font-family: monospace;
            padding: 15px; border-radius: 10px; font-size: 11px;
            overflow-x: auto; border: 1px solid #1a1a1a;
        }

        #dock {
            position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%);
            background: rgba(15, 15, 15, 0.9); backdrop-filter: blur(20px);
            padding: 15px 30px; border-radius: 40px; border: 1px solid rgba(255,255,255,0.1);
            display: flex; gap: 30px;
        }
        .dock-item { text-decoration: none; font-size: 24px; }
    </style>
</head>
<body>

    <h1 style="text-align:center; letter-spacing:2px; font-size:20px;">SYSTEM CONTROL BCS</h1>

    <div class="control-grid">
        <div class="pill-tile" id="tile-cellular" onclick="toggle('cellular')">
            <span>📡 DATA</span>
        </div>
        <div class="pill-tile" id="tile-flash" onclick="toggle('flashlight')">
            <span>🔦 FLASH</span>
        </div>
    </div>

    <div class="slider-box">
        <span style="font-size:10px; opacity:0.5;">LUMINANCE ENGINE</span>
        <input type="range" id="bright" oninput="Kernel.hardware.setBrightness(this.value); sync()">
    </div>

    <div class="dev-card">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
            <span style="color:var(--m-blue); font-size:12px; font-weight:900;">LIVE KERNEL SOURCE</span>
            <span style="font-size:10px; opacity:0.4;">v2.1-BCS</span>
        </div>
        <div class="code-block" id="source-code"></div>
    </div>

    <nav id="dock">
        <a href="foneai.html" class="dock-item">🧠</a>
        <a href="control.bcs.html" class="dock-item" style="color:var(--m-blue)">⚙️</a>
        <a href="index.html" class="dock-item">🏠</a>
        <a href="apps.html" class="dock-item">🔳</a>
    </nav>

    <script>
        function sync() {
            document.getElementById('tile-cellular').classList.toggle('active', Kernel.state.cellular);
            document.getElementById('tile-flash').classList.toggle('active', Kernel.state.flashlight);
            document.getElementById('source-code').innerText = JSON.stringify(Kernel.state, null, 4);
            document.getElementById('bright').value = Kernel.state.brightness;
        }

        function toggle(key) {
            if(key === 'flashlight') Kernel.hardware.toggleFlashlight();
            else { Kernel.state[key] = !Kernel.state[key]; Kernel.save(); }
            sync();
        }

        window.onload = sync;
    </script>
</body>
</html>
